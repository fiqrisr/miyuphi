---
// Floating Cinnamoroll-inspired background motifs.
// Uses CSS animations for gentle floating and a small client script for parallax.
// Respects prefers-reduced-motion: no scroll-driven movement when reduced motion is requested.
---

<div
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
  data-floating-background
>
  <!-- Cloud cluster top-left -->
  <div
    class="floating-bg-item absolute -left-12 top-[8%] w-64 text-blue-pale/40 md:w-96"
    data-speed="0.15"
  >
    <svg viewBox="0 0 200 120" fill="currentColor" class="animate-float-slow">
      <path
        d="M25 90c-13.8 0-25-11.2-25-25s11.2-25 25-25c2.5 0 4.9.4 7.2 1.1C37.6 21.8 59.4 8 84 8c21.8 0 40.7 12.2 50.3 30.1C139.4 33.2 146 32 153 32c24.3 0 44 19.7 44 44s-19.7 44-44 44H25z"
      ></path>
    </svg>
  </div>

  <!-- Cloud mid-right -->
  <div
    class="floating-bg-item absolute right-[5%] top-[22%] w-48 text-white/60 md:w-72"
    data-speed="0.25"
  >
    <svg
      viewBox="0 0 200 120"
      fill="currentColor"
      class="animate-float-delayed"
    >
      <path
        d="M50 100c-16.6 0-30-13.4-30-30s13.4-30 30-30c3 0 5.9.5 8.6 1.3C66.4 20.4 92.7 4 124 4c26.2 0 49 14.7 60.4 36.1C192.4 36.2 200 35 208 35c29.2 0 53 23.8 53 53s-23.8 53-53 53H50z"
      ></path>
    </svg>
  </div>

  <!-- Star / sparkle top-right -->
  <div
    class="floating-bg-item absolute right-[18%] top-[12%] w-10 text-yellow-soft/80 md:w-14"
    data-speed="0.35"
  >
    <svg viewBox="0 0 48 48" fill="currentColor" class="animate-float">
      <path
        d="M24 0l4.5 18.5L47 24l-18.5 5.5L24 48l-4.5-18.5L1 24l18.5-5.5L24 0z"
      ></path>
    </svg>
  </div>

  <!-- Heart / bubble left-mid -->
  <div
    class="floating-bg-item absolute left-[10%] top-[45%] w-12 text-pink-pastel/70 md:w-16"
    data-speed="0.2"
  >
    <svg viewBox="0 0 48 48" fill="currentColor" class="animate-float-slow">
      <path
        d="M24 42.7l-2.2-2C10.8 30.7 4 24.6 4 17 4 11 8.5 6.5 14.5 6.5c3.3 0 6.4 1.5 8.5 3.9C25.1 8.3 28 6.5 31.5 6.5 37.5 6.5 42 11 42 17c0 7.6-6.8 13.7-17.8 23.7l-2.2 2z"
      ></path>
    </svg>
  </div>

  <!-- Cloud bottom-left -->
  <div
    class="floating-bg-item absolute -bottom-8 -left-4 w-56 text-blue-pale/30 md:w-80"
    data-speed="0.1"
  >
    <svg viewBox="0 0 200 120" fill="currentColor" class="animate-float">
      <path
        d="M30 95c-13.8 0-25-11.2-25-25s11.2-25 25-25c2.5 0 4.9.4 7.2 1.1C42.6 26.8 64.4 13 89 13c21.8 0 40.7 12.2 50.3 30.1C144.4 38.2 151 37 158 37c24.3 0 44 19.7 44 44s-19.7 44-44 44H30z"
      ></path>
    </svg>
  </div>

  <!-- Star bottom-right -->
  <div
    class="floating-bg-item absolute bottom-[18%] right-[12%] w-8 text-yellow-soft/70 md:w-12"
    data-speed="0.3"
  >
    <svg viewBox="0 0 48 48" fill="currentColor" class="animate-float-delayed">
      <path
        d="M24 0l4.5 18.5L47 24l-18.5 5.5L24 48l-4.5-18.5L1 24l18.5-5.5L24 0z"
      ></path>
    </svg>
  </div>

  <!-- Small bubble right-lower -->
  <div
    class="floating-bg-item absolute bottom-[30%] right-[25%] w-6 text-white/50 md:w-10"
    data-speed="0.22"
  >
    <svg viewBox="0 0 40 40" fill="currentColor" class="animate-float-slow">
      <circle cx="20" cy="20" r="18"></circle>
    </svg>
  </div>
</div>

<script>
  (function initFloatingBackground() {
    const wrapper = document.querySelector("[data-floating-background]");
    if (!wrapper) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return;

    const items = wrapper.querySelectorAll<HTMLElement>(".floating-bg-item");
    if (items.length === 0) return;

    let ticking = false;

    function updateParallax() {
      const scrollY = window.scrollY;
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollY / docHeight : 0;

      items.forEach((item) => {
        const speed = parseFloat(item.dataset.speed ?? "0.2");
        const offset = progress * speed * 120;
        item.style.transform = `translate3d(0, ${offset}px, 0)`;
      });

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    updateParallax();
  })();
</script>
