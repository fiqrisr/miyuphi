---
import type { HeroContent } from "../data/content.ts";

interface Props {
  readonly content: HeroContent;
}

const { content } = Astro.props;
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 pt-24 sm:px-6 lg:px-8"
>
  <!-- Massive typographic background -->
  <div
    class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center text-center select-none"
  >
    <span
      class="font-display text-[clamp(4rem,18vw,16rem)] font-black leading-[0.85] tracking-tighter text-white/80"
    >
      Shimazaki
    </span>
    <span
      class="font-display text-[clamp(4rem,22vw,18rem)] font-black leading-[0.8] tracking-tighter text-white/80"
    >
      Miyu
    </span>
  </div>

  <!-- Foreground cutout placeholder -->
  <div class="relative z-10 flex flex-col items-center text-center">
    <div class="relative h-72 w-56 sm:h-96 sm:w-72 lg:h-[28rem] lg:w-80">
      <!-- Cutout image placeholder -->
      <div
        class="absolute inset-0 overflow-hidden rounded-[2.5rem] border-4 border-white/60 bg-gradient-to-b from-pink-pastel to-blue-pale shadow-soft"
      >
        <img
          src="/assets/profile-placeholder.svg"
          alt="Shimazaki Miyu portrait cutout"
          class="h-full w-full object-cover object-top"
          onerror="this.style.display='none'"
        />
        <div
          class="absolute inset-0 flex items-center justify-center text-center text-navy-deep/40"
          id="hero-placeholder-label"
        >
          <span class="font-display text-lg font-bold">Cutout Image</span>
        </div>
      </div>

      <!-- Floating caption pill -->
      <div
        class="absolute -right-4 top-12 rounded-full bg-surface-glass px-4 py-2 text-xs font-semibold text-navy-deep shadow-card backdrop-blur-md sm:-right-8 sm:text-sm"
      >
        Video Editor
      </div>
    </div>

    <p
      class="relative z-20 mt-6 max-w-md text-lg font-medium text-muted sm:text-xl"
    >
      {content.greeting}
    </p>
    <a
      href="#pricing"
      class="relative z-20 mt-4 inline-flex items-center justify-center rounded-full bg-pink-pastel px-8 py-3 font-semibold text-navy-deep shadow-card transition-all duration-200 hover:-translate-y-0.5 hover:bg-pink-200 hover:shadow-soft focus:outline-none focus-visible:ring-2 focus-visible:ring-navy-deep focus-visible:ring-offset-2"
    >
      View Pricelist
    </a>
  </div>
</section>

<script>
  // Hide placeholder label if image loads successfully.
  const img = document.querySelector(
    '#hero img[alt="Shimazaki Miyu portrait cutout"]',
  ) as HTMLImageElement | null;
  const label = document.getElementById("hero-placeholder-label");
  if (img && label) {
    img.addEventListener("load", () => {
      label.style.display = "none";
    });
  }
</script>
