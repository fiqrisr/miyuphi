---
import type { VideoPlatform } from "../data/content.ts";

interface Props {
  readonly platform: VideoPlatform;
  readonly videoUrl?: string;
  readonly gifUrl?: string;
  readonly embedUrl?: string;
  readonly label?: string;
}

const { platform, videoUrl = "", gifUrl = "", embedUrl = "", label } = Astro.props;

const isInstagram = platform === "instagram";
const platformLabel = isInstagram ? "Instagram" : "TikTok";

// Extract TikTok video ID from legacy embed URL (fallback for non-GIF data)
const tiktokVideoMatch = embedUrl.match(/tiktok\.com\/embed\/(\d+)/);
const tiktokVideoId = !isInstagram && tiktokVideoMatch ? tiktokVideoMatch[1] : "";

const iconPath = isInstagram
  ? "M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z M20 6h-2.5l-1.5-2h-7L7.5 6H5c-1.1 0-2 .9-2 2v9c0 1.1.9 2 2 2h15c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8 12.5c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z"
  : "M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z";
---

<div class="video-placeholder relative h-full w-full overflow-hidden rounded-[1.85rem] bg-neutral-900">
  {
    gifUrl ? (
      <a
        href={videoUrl || embedUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group/gif block h-full w-full"
        aria-label={`Buka video ${platformLabel}`}
      >
        <img
          src={gifUrl}
          alt={`Preview video ${platformLabel}`}
          class="h-full w-full object-cover transition-transform duration-300 group-hover/gif:scale-105"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 transition-opacity duration-300 group-hover/gif:opacity-100">
          <svg
            class="h-10 w-10 text-white drop-shadow-lg md:h-12 md:w-12"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </a>
    ) : isInstagram && embedUrl ? (
      <iframe
        src={embedUrl}
        title={`${platformLabel} video embed`}
        class="h-full w-full border-0"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    ) : tiktokVideoId ? (
      <blockquote
        class="tiktok-embed"
        cite={`https://www.tiktok.com/video/${tiktokVideoId}`}
        data-video-id={tiktokVideoId}
        style="max-width: 605px; min-width: 325px;"
      >
        <section>
          <a
            target="_blank"
            rel="noopener noreferrer"
            title="TikTok"
            href={`https://www.tiktok.com/video/${tiktokVideoId}`}
          >
            Watch on TikTok
          </a>
        </section>
      </blockquote>
    ) : embedUrl ? (
      <iframe
        src={embedUrl}
        title={`${platformLabel} video embed`}
        class="h-full w-full border-0"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full flex-col items-center justify-center gap-3 p-4 text-center text-white">
        <svg
          class="h-10 w-10 text-white/80"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d={iconPath} />
        </svg>
        <div class="space-y-1">
          <p class="text-sm font-semibold">{label || platformLabel}</p>
          <p class="max-w-[10rem] text-xs text-neutral-400">
            Tambahkan embed URL {platformLabel} di sini.
          </p>
        </div>
      </div>
    )
  }
</div>

<script>
  (function loadTikTokEmbedScript() {
    const src = "https://www.tiktok.com/embed.js";
    if (document.querySelector(`script[src="${src}"]`)) return;
    const script = document.createElement("script");
    script.src = src;
    script.async = true;
    document.body.appendChild(script);
  })();
</script>

<style>
  .video-placeholder :global(.tiktok-embed) {
    width: 100% !important;
    min-width: auto !important;
    max-width: none !important;
    height: 100% !important;
    margin: 0 !important;
    background: transparent !important;
    border-radius: inherit !important;
  }

  .video-placeholder :global(.tiktok-embed iframe) {
    width: 100% !important;
    height: 100% !important;
    border: 0 !important;
    border-radius: inherit !important;
  }
</style>
