---
import type { SiteContent, OrderStepIcon } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["orderFlow"];
}

const { content } = Astro.props;

const iconPaths: Record<OrderStepIcon, { path: string; viewBox?: string }> = {
  "pick-style": {
    path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z",
  },
  "fill-brief": {
    path: "M19 3h-4.18C14.4 1.84 13.3 1 12 1s-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z",
  },
  "secure-slot": {
    path: "M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z",
  },
  "send-ingredients": {
    path: "M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z",
    viewBox: "0 0 24 24",
  },
  "cooking-time": {
    path: "M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z",
  },
  "tasting-review": {
    path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z",
  },
  "payment-delivery": {
    path: "M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z",
  },
};

const accents = [
  "bg-pink-pastel text-navy-deep",
  "bg-yellow-soft text-navy-deep",
  "bg-blue-pale text-navy-deep",
  "bg-pink-pastel text-navy-deep",
  "bg-yellow-soft text-navy-deep",
  "bg-blue-pale text-navy-deep",
  "bg-pink-pastel text-navy-deep",
];
---

<section id="how-to-order" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <p class="font-display mb-4 text-center text-sm tracking-widest text-muted">
      {content.heading}
    </p>
    <h2 class="font-display mb-4 text-center text-5xl md:text-6xl">
      Dari Brief Sampai Viral
    </h2>
    <p class="mx-auto mb-16 max-w-2xl text-center text-muted">
      Tujuh langkah sederhana untuk mengubah footage mentahmu menjadi video rapi
      dan siap upload.
    </p>

    <div class="relative">
      {/* Central connector line */}
      <div
        class="absolute left-2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-pink-pastel via-yellow-soft to-blue-pale md:left-1/2 md:-translate-x-1/2"
        aria-hidden="true"
      >
      </div>

      <ol class="relative space-y-8 md:space-y-12">
        {
          content.steps.map((step, i) => {
            const isEven = i % 2 === 0;
            const accent = accents[i];
            const icon = iconPaths[step.icon];

            return (
              <li class="relative">
                {/* Timeline dot */}
                <div
                  class:list={[
                    "absolute left-2 top-8 z-10 flex h-5 w-5 -translate-x-1/2 items-center justify-center rounded-full border-2 border-white shadow-md md:left-1/2 md:-translate-x-1/2",
                    accent.split(" ")[0],
                  ]}
                  aria-hidden="true"
                >
                  <span class="h-2 w-2 rounded-full bg-navy-deep/60" />
                </div>

                <div
                  class:list={[
                    "flex flex-col gap-4 md:items-center",
                    isEven ? "md:flex-row" : "md:flex-row-reverse",
                  ]}
                >
                  {/* Empty spacer for alternating layout */}
                  <div class="hidden md:block md:w-1/2" />

                  {/* Card */}
                  <div class="pl-6 md:w-1/2 md:pl-0">
                    <div
                      class:list={[
                        "group glass-card relative rounded-3xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-soft",
                        isEven ? "md:mr-12" : "md:ml-12",
                      ]}
                    >
                      {/* Step number badge */}
                      <div
                        class:list={[
                          "absolute -top-4 flex h-10 w-10 items-center justify-center rounded-2xl font-display text-sm font-bold shadow-sm",
                          accent,
                          isEven ? "left-6 md:right-6 md:left-auto" : "left-6",
                        ]}
                      >
                        {step.n}
                      </div>

                      <div class="flex items-start gap-4 pt-3">
                        {/* Icon */}
                        <div
                          class:list={[
                            "flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl",
                            accent,
                          ]}
                        >
                          <svg
                            class="h-6 w-6"
                            viewBox={icon.viewBox ?? "0 0 24 24"}
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d={icon.path} />
                          </svg>
                        </div>

                        <div>
                          <h3 class="font-display mb-1 text-xl">
                            {step.title}
                          </h3>
                          <p class="text-sm leading-relaxed text-muted">
                            {step.description}
                          </p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
