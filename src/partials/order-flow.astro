---
import type { OrderFlowStep } from "../data/content.ts";

interface Props {
  readonly heading: string;
  readonly steps: readonly OrderFlowStep[];
}

const { heading, steps } = Astro.props;
---

<section id="how-to-order" class="py-16 sm:py-24">
  <div
    class="rounded-3xl border border-white/50 bg-surface-glass p-8 shadow-card backdrop-blur-xl sm:p-12"
  >
    <h2 class="font-display text-3xl font-bold text-foreground sm:text-4xl">
      {heading}
    </h2>
    <ol class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        steps.map((item) => (
          <li class="flex items-start gap-4 rounded-2xl border border-white/40 bg-white/50 p-4 shadow-card">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow-soft font-display text-sm font-bold text-navy-deep">
              {item.step}
            </span>
            <span class="pt-2 text-sm font-medium text-foreground sm:text-base">
              {item.title}
            </span>
          </li>
        ))
      }
    </ol>
  </div>
</section>
