---
import type { SiteContent } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["orderFlow"];
}

const { content } = Astro.props;
---

<section id="order" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <p class="font-display mb-4 text-center text-sm tracking-widest text-muted">
      {content.heading}
    </p>
    <h2
      class="font-display mb-12 text-center text-5xl md:text-6xl"
    >
      Easy as a Cloud ☁
    </h2>

    <div class="grid gap-6 md:grid-cols-4">
      {
        content.steps.map((s) => (
          <div class="glass rounded-3xl p-6 transition hover:-translate-y-2">
            <div
              class="font-display mb-2 text-4xl text-pink-pastel"
              style={{ WebkitTextStroke: "1px #1e2a4a" }}
            >
              {s.n}
            </div>
            <h3 class="font-display mb-2 text-xl">{s.title}</h3>
            <p class="text-sm text-muted">{s.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
