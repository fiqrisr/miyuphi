---
import type { AboutContent } from "../data/content.ts";

interface Props {
  readonly content: AboutContent;
}

const { content } = Astro.props;
---

<section id="about" class="py-16 sm:py-24">
  <div
    class="rounded-3xl border border-white/50 bg-surface-glass p-8 shadow-card backdrop-blur-xl sm:p-12"
  >
    <h2 class="font-display text-3xl font-bold text-foreground sm:text-4xl">
      {content.heading}
    </h2>
    <div class="mt-6 space-y-4 text-base leading-relaxed text-muted sm:text-lg">
      {content.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <ul class="mt-8 space-y-3">
      {
        content.contacts.map((contact) => (
          <li class="flex flex-col sm:flex-row sm:items-center sm:gap-3">
            <span class="text-sm font-semibold uppercase tracking-wide text-navy-deep/70">
              {contact.label}
            </span>
            <a
              href={contact.href}
              target={contact.href.startsWith("http") ? "_blank" : undefined}
              rel={
                contact.href.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
              class="text-base text-foreground underline decoration-pink-pastel decoration-2 underline-offset-4 transition-colors hover:text-pink-400"
            >
              {contact.value}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
