---
import type { SiteContent } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["about"];
}

const { content } = Astro.props;

const contactMeta: Record<
  string,
  { icon: string; prefix: string; aria: string }
> = {
  Email: {
    icon: "M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 2v.51l-8 5.24L4 6.51V6h16zM4 18V9.02l7.39 4.83a2 2 0 0 0 2.22 0L20 9.02V18H4z",
    prefix: "",
    aria: "Email",
  },
  Telepon: {
    icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
    prefix: "",
    aria: "Telepon / WhatsApp",
  },
  Instagram: {
    icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z",
    prefix: "",
    aria: "Instagram",
  },
  TikTok: {
    icon: "M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z",
    prefix: "",
    aria: "TikTok",
  },
};
---

<section id="about" class="px-6 py-24">
  <div class="glass-card mx-auto max-w-4xl rounded-[2.5rem] p-10 md:p-16">
    <p class="font-display mb-4 text-sm tracking-widest text-muted">
      {content.heading}
    </p>
    <h2 class="font-display mb-6 text-5xl md:text-6xl">{content.greeting}</h2>

    <p class="text-lg leading-relaxed text-muted">
      {content.intro.before}
      {
        content.intro.categories.map((cat, i, arr) => {
          const isLast = i === arr.length - 1;
          return (
            <>
              {i > 0 && (isLast ? " dan " : ", ")}
              <span class={`rounded ${cat.colorClass} px-2`}>{cat.label}</span>
            </>
          );
        })
      }
      {content.intro.after}
    </p>

    {
      content.paragraphs.map((p) => (
        <p class="mt-4 text-lg leading-relaxed text-muted">{p}</p>
      ))
    }

    <div class="mt-10 flex flex-wrap gap-3">
      {
        content.contacts.map((contact) => {
          const meta = contactMeta[contact.label] ?? {
            icon: "",
            prefix: "",
            aria: contact.label,
          };
          const isExternal = contact.href.startsWith("http");
          return (
            <a
              href={contact.href}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              aria-label={meta.aria}
              class="group glass flex items-center gap-3 rounded-full px-4 py-2.5 text-sm font-semibold text-foreground transition hover:scale-105 hover:bg-white/40"
            >
              <svg
                class="h-4 w-4 shrink-0 text-muted transition group-hover:text-foreground"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={meta.icon} />
              </svg>
              <span class="truncate">
                {meta.prefix}
                {contact.value}
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
