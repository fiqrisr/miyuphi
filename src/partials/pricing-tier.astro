---
import type { SiteContent } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["pricing"];
}

const { content } = Astro.props;
---

<section id="pricelist" class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <p class="font-display mb-4 text-center text-sm tracking-widest text-muted">
      {content.heading}
    </p>
    <h2 class="font-display mb-4 text-center text-5xl md:text-6xl">
      Pick Your Style
    </h2>
    <p class="mb-12 text-center text-muted">{content.subtitle}</p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        content.styles.map((s, i) => (
          <div
            class="glass relative overflow-hidden rounded-3xl p-6 transition-all duration-500 hover:-translate-y-3"
            style={{ animationDelay: `${i * 100}ms` }}
          >
            <div
              class="absolute -right-10 -top-10 h-32 w-32 rounded-full opacity-60"
              style={{ background: s.color }}
            />
            <div class="relative">
              <h3 class="font-display mb-1 text-3xl">{s.name}</h3>
              <div class="font-display text-4xl text-foreground">
                <span class="font-sans text-base text-muted">Rp</span>
                {s.price}
              </div>
              <div class="mb-6 text-xs text-muted">/menit</div>
              <ul class="space-y-3 text-sm text-muted">
                {s.features.map((f) => (
                  <li class="flex gap-2">
                    <span class="mt-0.5 text-pink-pastel">♡</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
