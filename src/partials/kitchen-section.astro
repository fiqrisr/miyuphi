---
import type { SiteContent } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["kitchenSection"];
}

const { content } = Astro.props;

const hasTikTok = content.accounts.some((a) => a.platform === "tiktok");

const platformMeta: Record<
  SiteContent["kitchenSection"]["accounts"][number]["platform"],
  { label: string; iconPath: string; brandClass: string }
> = {
  tiktok: {
    label: "TikTok",
    brandClass: "bg-black text-white",
    iconPath:
      "M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z",
  },
  instagram: {
    label: "Instagram",
    brandClass:
      "bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-600 text-white",
    iconPath:
      "M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z",
  },
};
---

<section id="kitchen" class="relative px-6 py-24">
  <div class="mx-auto max-w-7xl">
    <p class="font-display mb-3 text-center text-sm tracking-widest text-muted">
      ♡ PORTFOLIO
    </p>
    <h2
      class="font-display mb-4 text-center text-5xl text-foreground md:text-6xl lg:text-7xl"
    >
      {content.heading}
    </h2>
    <p class="mx-auto mb-8 max-w-2xl text-center text-muted">
      {content.subtitle}
    </p>

    <div class="mb-10 flex flex-wrap justify-center gap-3">
      {
        content.accounts.map((account) => {
          const meta = platformMeta[account.platform];
          return (
            <a
              href={account.profileUrl}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold shadow-soft transition hover:scale-105",
                meta.brandClass,
              ]}
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={meta.iconPath} />
              </svg>
              {account.handle}
            </a>
          );
        })
      }
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {
        content.accounts.map((account) => {
          const meta = platformMeta[account.platform];

          return (
            <article class="glass flex flex-col overflow-hidden rounded-3xl p-4 md:p-6">
              <header class="mb-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span
                    class:list={[
                      "flex h-10 w-10 shrink-0 items-center justify-center rounded-full",
                      meta.brandClass,
                    ]}
                  >
                    <svg
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d={meta.iconPath} />
                    </svg>
                  </span>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-muted">
                      {meta.label}
                    </p>
                    <a
                      href={account.profileUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-display font-bold text-foreground hover:underline"
                    >
                      {account.handle}
                    </a>
                  </div>
                </div>
              </header>

              <div class="relative flex w-full items-center justify-center overflow-hidden rounded-2xl bg-neutral-100 aspect-[9/16] max-h-[640px]">
                {account.platform === "tiktok" ? (
                  <blockquote
                    class="tiktok-embed"
                    cite={account.profileUrl}
                    data-unique-id={account.handle.replace("@", "")}
                    data-embed-type="creator"
                    style="max-width: 780px; min-width: 288px;"
                  >
                    <section>
                      <a
                        target="_blank"
                        href={`${account.profileUrl}?refer=creator_embed`}
                      >
                        {account.handle}
                      </a>
                    </section>
                  </blockquote>
                ) : (
                  <iframe
                    src={account.embedUrl}
                    title={`Feed ${meta.label} ${account.handle}`}
                    class="absolute inset-0 h-full w-full border-0"
                    allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
                    loading="lazy"
                  />
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>

  {hasTikTok && <script is:inline async src="https://www.tiktok.com/embed.js"></script>}
</section>
