---
import type { SiteContent } from "../data/content.ts";

interface Props {
  readonly content: SiteContent["contact"];
}

const { content } = Astro.props;
---

<section id="contact" class="px-6 py-32">
  <div class="glass mx-auto max-w-3xl rounded-[2.5rem] p-12 text-center md:p-16">
    <p class="font-display text-2xl text-muted">{content.subtitle}</p>
    <h2 class="font-display my-4 whitespace-pre-line text-6xl md:text-8xl">
      {content.heading}
    </h2>
    <p class="mx-auto mb-8 max-w-md text-lg text-muted">
      {content.description}
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      {
        content.links.map((link, idx) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noreferrer" : undefined}
            class={`rounded-full px-6 py-3 font-bold shadow-soft transition hover:scale-105 ${
              idx === 0
                ? "bg-foreground text-background"
                : "bg-pink-pastel text-foreground"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
