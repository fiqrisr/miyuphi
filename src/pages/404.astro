---
import Layout from "../layouts/layout.astro";
---

<Layout
  title="Halaman tidak ditemukan — Yuphi"
  description="Halaman yang kamu cari tidak ada atau sudah dipindahkan."
>
  <div class="flex min-h-screen items-center justify-center bg-background px-4">
    <div class="max-w-md text-center">
      <h1 class="text-7xl font-bold text-foreground">404</h1>
      <h2 class="mt-4 text-xl font-semibold text-foreground">
        Halaman tidak ditemukan
      </h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Halaman yang kamu cari tidak ada atau sudah dipindahkan.
      </p>
      <div class="mt-6">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Kembali ke beranda
        </a>
      </div>
    </div>
  </div>
</Layout>
